<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@drawable/card_bg2" android:orientation="vertical"
    android:padding="12dp" android:layout_marginBottom="8dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
        <TextView android:id="@+id/tv_step_num" android:layout_width="26dp" android:layout_height="26dp"
            android:background="@drawable/circle_pink" android:textColor="#fff"
            android:textSize="12sp" android:gravity="center" android:layout_marginEnd="8dp"/>
        <EditText android:id="@+id/et_step_emoji" android:layout_width="44dp" android:layout_height="40dp"
            android:background="@drawable/input_bg" android:textSize="18sp" android:gravity="center" android:padding="4dp" android:layout_marginEnd="8dp"/>
        <EditText android:id="@+id/et_step_name" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
            android:hint="Step name" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
            android:background="@drawable/input_bg" android:padding="8dp" android:textSize="13sp" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_remove_step" android:layout_width="34dp" android:layout_height="34dp"
            android:text="✕" android:background="@drawable/card_bg" android:textColor="@color/red" android:textSize="13sp" android:padding="0dp"/>
    </LinearLayout>
    <EditText android:id="@+id/et_step_notes" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Notes (optional)" android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
        android:background="@drawable/input_bg" android:padding="8dp" android:textSize="12sp" android:layout_marginBottom="8dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Duration:" android:textColor="@color/text_muted" android:textSize="12sp" android:layout_marginEnd="8dp"/>
        <EditText android:id="@+id/et_step_mins" android:layout_width="50dp" android:layout_height="36dp"
            android:inputType="number" android:textColor="@color/text_primary" android:background="@drawable/input_bg"
            android:padding="4dp" android:textSize="14sp" android:gravity="center" android:hint="0"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="m" android:textColor="@color/text_muted" android:textSize="12sp" android:layout_marginStart="4dp" android:layout_marginEnd="8dp"/>
        <EditText android:id="@+id/et_step_secs" android:layout_width="50dp" android:layout_height="36dp"
            android:inputType="number" android:textColor="@color/text_primary" android:background="@drawable/input_bg"
            android:padding="4dp" android:textSize="14sp" android:gravity="center" android:hint="60"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="s" android:textColor="@color/text_muted" android:textSize="12sp" android:layout_marginStart="4dp"/>
    </LinearLayout>
    <Spinner android:id="@+id/spinner_product" android:layout_width="match_parent" android:layout_height="40dp"
        android:background="@drawable/input_bg" android:popupBackground="@color/card2"/>
</LinearLayout>